#!/usr/bin/env bash

set -e

# Colors for readable terminal output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${YELLOW}Starting selective pre-commit checks...${NC}"

# Get only currently staged files (Added, Copied, Modified, Renamed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No files in stage. Commit allowed.${NC}"
    exit 0
fi

BACKEND_FILES=""
FRONTEND_FILES=""
WORKFLOW_FILES=""

# Sort files into their respective categories based on path
for FILE in $STAGED_FILES; do
    if [[ "$FILE" == backend/*.py ]]; then
        BACKEND_FILES="$BACKEND_FILES $FILE"
    elif [[ "$FILE" == frontend/* && "$FILE" =~ \.(js|ts|jsx|tsx|json|css)$ ]]; then
        FRONTEND_FILES="$FRONTEND_FILES $FILE"
    elif [[ "$FILE" == .github/workflows/*.yml || "$FILE" == .github/workflows/*.yaml ]]; then
        WORKFLOW_FILES="$WORKFLOW_FILES $FILE"
    fi
done

HAS_ERRORS=0

# ==========================================
# BACKEND CHECKS (Python)
# ==========================================

if [ -n "$BACKEND_FILES" ]; then
    echo -e "${YELLOW}--> Backend changes detected. Running Black and Flake8...${NC}"

    if command -v isort >/dev/null 2>&1; then
        isort --profile black $BACKEND_FILES
    else
        echo -e "${RED}Warning: 'isort' not found in PATH.${NC}"
    fi

    if command -v black >/dev/null 2>&1; then
        black $BACKEND_FILES
    else
        echo -e "${RED}Warning: 'black' not found in PATH.${NC}"
    fi

    if command -v flake8 >/dev/null 2>&1; then
        if ! flake8 --max-line-length=88 $BACKEND_FILES; then
            echo -e "${RED}Error: Flake8 linting failed on backend.${NC}"
            HAS_ERRORS=1
        fi
    else
        echo -e "${RED}Warning: 'flake8' not found in PATH.${NC}"
    fi

    # Re-add staged files in case black formatted them
    git add $BACKEND_FILES
fi

# ==========================================
# FRONTEND CHECKS (Node/React)
# ==========================================

if [ -n "$FRONTEND_FILES" ]; then
    echo -e "${YELLOW}--> Frontend changes detected. Running Prettier and ESLint...${NC}"

    (
        cd frontend || exit 1

        LOCAL_FRONTEND_FILES="${FRONTEND_FILES//frontend\//}"

        # Run Prettier
        if npx --no-install prettier --write $LOCAL_FRONTEND_FILES >/dev/null 2>&1; then
            echo "Frontend files formatted with Prettier."
        else
            echo -e "${RED}Warning: Unable to run Prettier.${NC}"
        fi

        # Run ESLint
        if ! ESLINT_USE_FLAT_CONFIG=true npx --no-install eslint --fix $LOCAL_FRONTEND_FILES; then
            exit 1
        fi
    )

    if [ $? -ne 0 ]; then
        echo -e "${RED}Error: ESLint failed on frontend.${NC}"
        HAS_ERRORS=1
    fi

    git add $FRONTEND_FILES
fi

# ==========================================
# WORKFLOWS YAML CHECKS
# ==========================================

if [ -n "$WORKFLOW_FILES" ]; then
    echo -e "${YELLOW}--> Workflow changes detected. Running Yamllint...${NC}"

    if npx --no-install prettier --write $WORKFLOW_FILES >/dev/null 2>&1; then
        echo "Workflows formatted with Prettier."
    fi

    if command -v yamllint >/dev/null 2>&1; then
        # Run syntax linting for YAML files
        if ! yamllint $WORKFLOW_FILES; then
            echo -e "${RED}Error: YAML linting failed.${NC}"
            HAS_ERRORS=1
        fi
    else
        echo -e "${RED}Warning: 'yamllint' is not installed locally.${NC}"
    fi

    git add $WORKFLOW_FILES
fi

# ==========================================
# FINAL VERIFICATION
# ==========================================

if [ $HAS_ERRORS -eq 1 ]; then
    echo -e "\n${RED}✗ Commit blocked due to linting errors. Please fix the issues and try again.${NC}"
    exit 1
fi

echo -e "\n${GREEN}✓ All pre-commit checks passed successfully!${NC}"
exit 0
